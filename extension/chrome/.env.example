# Copy to .env for local development (never commit .env)

# Comma-separated TronGrid Pro keys — https://www.trongrid.io/
VITE_TRONGRID_API_KEYS=

# Sponsorship relay (production URL or local wrangler dev)
VITE_RELAY_URL=https://mesh-sponsorship-relay.meshwallet.workers.dev

# Bearer token matching worker RELAY_AUTH_SECRET
VITE_RELAY_AUTH_SECRET=
