    "privacy.receive.body": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To receive USDT safely, open Receive and tap Generate another address. Each payment can use a new wallet address so senders cannot link them to your main balance."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Para recibir USDT en privado, abre Recibir y pulsa Generar otra dirección. Cada pago puede usar una dirección nueva para que no se vincule con tu saldo principal."
          }
        },
        "id": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Untuk menerima USDT secara privat, buka Terima dan ketuk Buat alamat lain. Setiap pembayaran bisa memakai alamat baru agar pengirim tidak menghubungkannya dengan saldo utama."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "USDT'yi gizlice almak için Al'a gidin ve Yeni adres oluştur'a dokunun. Her ödeme yeni bir adres kullanabilir; gönderenler bunları ana bakiyenizle ilişkilendiremez."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Để nhận USDT riêng tư, mở Nhận và nhấn Tạo địa chỉ khác. Mỗi thanh toán có thể dùng địa chỉ mới để người gửi không liên kết với số dư chính."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لاستلام USDT بأمان، افتح الاستلام واضغط إنشاء عنوان آخر. يمكن لكل دفعة استخدام عنوان محفظة جديد حتى لا يربط المرسلون بينها وبين رصيدك الرئيسي."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "要安全接收 USDT，请打开收款并点击生成另一个地址。每笔付款可使用新钱包地址，发送方无法将其与你的主余额关联。"
          }
        }
      }
    },
    "privacy.receive.title": {
      "extractionState": "stale",
      "localizations": {
