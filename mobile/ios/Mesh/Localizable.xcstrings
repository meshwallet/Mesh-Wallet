    "ai.organizer.subtitle": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Groups your activity locally on this device. Nothing is sent to Mesh servers."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agrupa tu actividad localmente en el dispositivo. No se envía a servidores Mesh."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mengelompokkan aktivitas secara lokal di perangkat. Tidak dikirim ke server Mesh."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hareketlerinizi yalnızca bu cihazda gruplar. Mesh sunucularına gönderilmez."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhóm hoạt động cục bộ trên thiết bị. Không gửi lên máy chủ Mesh."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يجمع نشاطك محليًا على هذا الجهاز. لا يُرسل شيء إلى خوادم Mesh."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在本地设备上整理你的活动。不会发送到 Mesh 服务器。"
          }
        }
      }
    },
