    "privacy.send.body": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap a method to set the default for Send. The send fee is added to your transfer total and shown before you confirm."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca un método para establecer el predeterminado en Enviar. La comisión se suma al total y se muestra antes de confirmar."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ketuk metode untuk mengatur default Kirim. Biaya kirim ditambahkan ke total transfer dan ditampilkan sebelum konfirmasi."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Varsayılan gönderim yöntemini seçmek için bir yönteme dokunun. Gönderim ücreti toplam tutara eklenir ve onaydan önce gösterilir."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chạm vào phương thức để đặt mặc định cho Gửi. Phí gửi được cộng vào tổng và hiển thị trước khi xác nhận."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط طريقة لتعيين الافتراضي للإرسال. تُضاف رسوم الإرسال إلى إجمالي التحويل وتُعرض قبل التأكيد."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击方式以设置发送默认值。发送手续费会加入转账总额，并在确认前显示。"
          }
        }
      }
    },
