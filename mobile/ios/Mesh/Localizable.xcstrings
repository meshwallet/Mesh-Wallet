    "appUpdate.message": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Version %@ is available on the App Store. Update for the latest fixes and features."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La versión %@ está disponible en el App Store. Actualiza para obtener las últimas mejoras."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Versi %@ tersedia di App Store. Perbarui untuk fitur dan perbaikan terbaru."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ sürümü App Store'da mevcut. En son düzeltmeler için güncelleyin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phiên bản %@ đã có trên App Store. Hãy cập nhật để nhận tính năng mới nhất."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الإصدار %@ متاح على App Store. حدّث للحصول على أحدث الإصلاحات والميزات."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "App Store 上有 %@ 版本可用。更新以获取最新修复和功能。"
          }
        }
      }
    },
