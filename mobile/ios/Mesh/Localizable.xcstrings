    "receive.delete.address.message": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ will be removed from your balance list. Funds on this address stay on-chain."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ se eliminará de tu lista. Los fondos en esta dirección siguen en la cadena."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ akan dihapus dari daftar. Dana di alamat ini tetap di on-chain."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ будет удалён из списка аккаунтов. Средства на этом адресе останутся в сети."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ listeden kaldırılacak. Bu adresteki bakiye zincirde kalır."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ sẽ bị xóa khỏi danh sách. Số dư trên địa chỉ này vẫn còn on-chain."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيُزال %@ من قائمة أرصدتك. الأموال على هذا العنوان تبقى على السلسلة."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 将从余额列表中移除。该地址上的资金仍保留在链上。"
          }
        }
      }
    },
