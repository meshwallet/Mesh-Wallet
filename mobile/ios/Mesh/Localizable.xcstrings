    "privacy.protection.item1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Receive: your main address by default — generate a new one on Receive for private incoming payments"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recibir: dirección principal por defecto — genera una nueva en Recibir para pagos privados"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Terima: alamat utama default — buat alamat baru di Terima untuk pembayaran masuk privat"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Al: varsayılan ana adresiniz — gizli gelen ödemeler için Al'da yeni adres oluşturun"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhận: địa chỉ chính mặc định — tạo địa chỉ mới trong Nhận cho thanh toán riêng tư"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الاستلام: عنوانك الرئيسي افتراضيًا — أنشئ عنوانًا جديدًا في الاستلام للمدفوعات الواردة الخاصة"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "收款：默认使用主地址——在收款页面生成新地址以进行隐私收款"
          }
        }
      }
    },
    "privacy.protection.item2": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Send opens with your default method — you can still change it on each transfer"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Enviar abre con tu método predeterminado — puedes cambiarlo en cada transferencia"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kirim dibuka dengan metode default — Anda bisa mengubahnya setiap transfer"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gönder varsayılan yönteminizle açılır — her transferde değiştirebilirsiniz"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gửi mở bằng phương thức mặc định — bạn vẫn có thể đổi mỗi lần chuyển"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الإرسال يفتح بطريقتك الافتراضية — يمكنك تغييرها في كل تحويل"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发送默认使用你的默认方式——每次转账仍可更改"
          }
        }
      }
    },
    "privacy.protection.item3": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Each new receive address is separate on-chain"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada nueva dirección de recepción es independiente on-chain"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Setiap alamat terima baru terpisah on-chain"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her yeni alım adresi zincirde ayrıdır"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mỗi địa chỉ nhận mới tách biệt trên chuỗi"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
